{
  "provider": "minimax",
  "cli": "mmx",
  "auth_check": "mmx auth status",
  "synthesize_template": {
    "command": "mmx speech synthesize",
    "params": {
      "text": "{{text}}",
      "voice": "{{voice_id}}",
      "out": "{{output_path}}",
      "subtitles": true
    }
  },
  "voice_map": {
    "沉稳男声": "male-qn-qingse",
    "活力女声": "female-shaonv",
    "专业播音": "presenter_male",
    "默认": "male-qn-qingse"
  },
  "defaults": {
    "speed": 1.0,
    "language": "zh"
  }
}
