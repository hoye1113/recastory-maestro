{
  "provider": "minimax",
  "cli": "mmx",
  "auth_check": "mmx auth status",
  "synthesize_template": {
    "command": "mmx speech synthesize",
    "params": {
      "text": "{{text}}",
      "voice": "{{voice_id}}",
      "out": "{{output_path}}",
      "subtitles": true
    }
  },
  "voice_map": {
    "沉稳男声": "male-qn-qingse",
    "活力女声": "female-shaonv",
    "专业播音": "presenter_male",
    "默认": "male-qn-qingse"
  },
  "defaults": {
    "speed": 1.0,
    "language": "zh"
  },
  "quota": {
    "daily_limit": 4000,
    "check_before_batch": true,
    "exhausted_action": "stop_keep_synthesized"
  },
  "retry": {
    "max_retries": 1,
    "retry_on": ["timeout", "network_error"],
    "do_not_retry_on": ["quota_exhausted", "auth_error"]
  }
}
